# Normalize line endings: store everything as LF in the repo, check out
# native on each platform. This silences the LF/CRLF warnings on Windows.
* text=auto

# Source and config -> always LF
*.kt        text eol=lf
*.kts       text eol=lf
*.java       text eol=lf
*.xml       text eol=lf
*.md         text eol=lf
*.properties text eol=lf
*.pro        text eol=lf
*.gitignore  text eol=lf
*.gitattributes text eol=lf

# Windows scripts -> CRLF
*.bat       text eol=crlf

# Unix scripts -> LF
gradlew     text eol=lf

# Binaries -> never touched
*.jar       binary
*.png       binary
*.jpg       binary
*.webp      binary
*.keystore  binary
*.ttf       binary
